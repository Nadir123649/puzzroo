{
  "extends": "next/core-web-vitals",
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "react-hot-toast",
            "importNames": ["default", "toast"],
            "message": "Use the centralized `notify` wrapper from '@/lib/toast' instead of importing `toast` directly."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/lib/toast/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
