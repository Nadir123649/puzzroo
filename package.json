{
  "name": "puzzroo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "sudoku:generate": "py tools/puzzle-generators/export_sudoku.py --difficulty all --count 1000",
    "sudoku:validate": "py tools/puzzle-generators/validate_sudoku_dataset.py --min-count 900",
    "crossmath:generate": "py tools/puzzle-generators/export_crossmath.py --difficulty all --count 1000",
    "crossmath:validate": "py tools/puzzle-generators/validate_crossmath_dataset.py --min-count 900",
    "nonogram:generate": "py tools/puzzle-generators/export_nonogram.py --difficulty all --count 1000",
    "nonogram:validate": "py tools/puzzle-generators/validate_nonogram_dataset.py --min-count 1000",
    "db:seed": "tsx scripts/seed-puzzles.ts",
    "db:seed:dry": "tsx scripts/seed-puzzles.ts --dry"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.17.0",
    "mongoose": "^9.7.4",
    "multer-storage-cloudinary": "^4.0.0",
    "next": "^16.2.7",
    "nodemailer": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.8.1",
    "react-hot-toast": "^2.6.0",
    "sharp": "^0.35.3",
    "stripe": "^22.3.1",
    "tailwind-merge": "^2.5.4",
    "ua-parser-js": "^2.0.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.43",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ua-parser-js": "^0.7.39",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^16.2.7",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.23.1",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "jose": "^5.9.6"
  }
}
